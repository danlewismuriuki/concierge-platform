# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=concierge

# Redis (local queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS (production queue)
AWS_REGION=us-east-1
SQS_QUEUE_URL=
SQS_DLQ_URL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_SECRET=

# Services
API_SERVICE_URL=http://localhost:3000
IVR_SERVICE_URL=http://localhost:3001
WEBHOOK_SERVICE_URL=http://localhost:3002

# Worker
WORKER_ID=worker-1
MAX_JOB_ATTEMPTS=5
JOB_VISIBILITY_TIMEOUT_SECONDS=60
STALE_JOB_TIMEOUT_MINUTES=10

# Environment
NODE_ENV=development
